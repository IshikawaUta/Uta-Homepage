{
  "outputDirectory": "public",
  "framework": null,
  "installCommand": "uv pip install --system -r requirements.txt",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/css/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/js/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ]
}
